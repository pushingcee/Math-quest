// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ProblemSet {
  id        String   @id @default(cuid())
  name      String
  data      String   // JSON-serialized ImportedProblemsData
  createdAt DateTime @default(now())
}
